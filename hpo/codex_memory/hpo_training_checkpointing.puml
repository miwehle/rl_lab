Objective -> Trainer : [[WORKSPACE_ROOT/dqn/src/dqn/vector_training.py:175:1 train(config, plotter)]]
activate Trainer

loop after one or more episodes finish
    Trainer -> Recorder : [[WORKSPACE_ROOT/hpo/src/hpo/checkpointing.py:94:1 after_episode(...)]]
