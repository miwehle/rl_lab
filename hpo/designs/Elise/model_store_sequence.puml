@startuml
title Modell speichern mit loser Kopplung

actor Optuna
participant "objective.py" as Objective
participant "VectorTrainer" as Trainer
participant "model_store.py" as Store
database "SQLite\nTrial-Attribute" as DB
collections "Checkpoint-Dateien" as Files

Optuna -> Objective: Trial starten
Objective -> Trainer: train(config)
Trainer --> Objective: q_net, returns
Objective -> Objective: Score berechnen

alt model_store aktiviert
    Objective -> Store: save_q_net(q_net, metadata)
    Store -> Files: state_dict + metadata speichern
    Store --> Objective: model_path
    Objective -> DB: trial.user_attr["model_path"] = model_path
end

Objective --> Optuna: score

@enduml
