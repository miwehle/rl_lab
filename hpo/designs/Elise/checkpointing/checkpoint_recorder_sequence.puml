@startuml
title Bestes Modell waehrend des Trainings sichern

hide footbox

participant "objective\n(trainer per Hook: CheckpointingTrainer)" as Objective
participant "checkpointing.py" as Checkpointing
participant "trainer:CheckpointingTrainer" as Trainer
participant "recorder:BestCheckpointRecorder" as Recorder

Objective -> Checkpointing: for_trial(trial, training_config)
create Recorder
Checkpointing -> Recorder: new BestCheckpointRecorder(...)
Checkpointing --> Objective: hooks

Objective -> Checkpointing: hooks.make_trainer(env, seed, device, replay_memory_capacity)
create Trainer
Checkpointing -> Trainer: new CheckpointingTrainer(..., checkpoint_recorder)
Checkpointing --> Objective: trainer

Objective -> Trainer: train(training_config)

loop pro Episode
    note right of Trainer
        train() ruft den Recorder ueber
        den Trainer-Hook nach Episodenabschluss auf.
    end note
    Trainer -> Recorder: after_episode(trainer, episode_returns)
    alt Fenster-Score verbessert
        Recorder -> Checkpointing: save_model_checkpoint(q_net, path, metadata)
        Checkpointing --> Recorder: checkpoint gespeichert
    end
end

Trainer --> Objective: TrainingResult

Objective -> Checkpointing: hooks.q_net_for_evaluation(result.q_net, trainer.device)
alt bester Checkpoint vorhanden
    Checkpointing -> Checkpointing: load_model_checkpoint(q_net, path, device)
end
Checkpointing --> Objective: q_net

Objective -> Checkpointing: hooks.save_trial_attrs(save)
alt bester Checkpoint vorhanden
    Checkpointing --> Objective: checkpoint attrs gespeichert
end

Objective --> Objective: score zurueckgeben

@enduml
