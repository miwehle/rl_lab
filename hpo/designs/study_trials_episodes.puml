@startuml

!include ../../puml_links.iuml

title Optuna Study, Trials und Gym Episodes

hide footbox

actor "Aufrufer" as Caller

participant "study_runner" as Runner
participant "objective" as Objective
participant "study:Optuna Study" as Study #FFF2CC
participant "trial:Optuna Trial" as Trial #FFF2CC
participant "trainer" as Trainer

url of Runner is [[WORKSPACE_ROOT/hpo/src/hpo/study.py:52:1]]
url of Objective is [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:134:1]]
url of Study is [[WORKSPACE_ROOT/hpo/src/hpo/study.py:279:1]]
url of Trial is [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:142:1]]
url of Trainer is [[WORKSPACE_ROOT/dqn/src/dqn/vector_training.py:115:1]]

create Runner
Caller -> Runner: new StudyRunner(...)

Caller -> Runner: [[WORKSPACE_ROOT/hpo/src/hpo/study.py:71:1 run(...)]]
activate Runner

create Objective
Runner -> Objective: [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:134:1 create_objective(...)]]

create Study
Runner -> Study: [[WORKSPACE_ROOT/hpo/src/hpo/study.py:279:1 create_study(..., load_if_exists=True)]]

Runner -> Study: [[WORKSPACE_ROOT/hpo/src/hpo/study.py:173:1 optimize(objective)]]
activate Study

loop pro Trial
    create Trial
    Study -> Trial: [[https://optuna.readthedocs.io/en/stable/reference/generated/optuna.trial.Trial.html <<create>>]]

    Study -> Objective: [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:142:1 objective(trial)]]
    activate Objective

    Objective -> Trial: [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:143:1 suggest_*(...)]]
    activate Trial
    Trial --> Objective: parameter value
    deactivate Trial

    create Trainer
    Objective -> Trainer: [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:156:1 make_trainer(...)]]

    Objective -> Trainer: [[WORKSPACE_ROOT/dqn/src/dqn/vector_training.py:166:1 train(training_config)]]
    activate Trainer

    loop pro Gym Episode
        note over Trainer #FFF2CC: Gym Episode
        Trainer -> Trainer: env.reset(...), viele env.step(...)
    end

    Trainer --> Objective: TrainingResult
    deactivate Trainer

    Objective -> Trial: [[WORKSPACE_ROOT/hpo/src/hpo/objective.py:186:1 set_user_attr(...)]]
    activate Trial
    deactivate Trial

    Objective --> Study: score
    deactivate Objective
end

note right of Study
    Optuna speichert den score
    im Trial der Study.
end note

deactivate Study

Runner -> Runner: [[WORKSPACE_ROOT/hpo/src/hpo/study.py:114:1 incumbent_score aktualisieren]]
Runner -> Runner: [[WORKSPACE_ROOT/hpo/src/hpo/study.py:123:1 study in studies ablegen]]

deactivate Runner

@enduml
